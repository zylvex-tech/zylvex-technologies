# JWT Authentication Service Configuration

# Database
# REQUIRED — use the same password as AUTH_DB_PASSWORD in docker-compose
DATABASE_URL=postgresql://auth_user:auth_pass_changeme@localhost:5432/auth_db

# JWT Secrets
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security
BCRYPT_ROUNDS=12

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=false

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
