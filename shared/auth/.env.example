# JWT Authentication Service Configuration

# Database
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/auth_db

# JWT Secrets
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security
BCRYPT_ROUNDS=12

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=false

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# SendGrid — leave empty to log emails to console instead of sending (dev mode)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@zylvex.io
EMAIL_FROM_NAME=Zylvex

# Frontend URL — used to build email verification and password reset links
FRONTEND_URL=http://localhost:3000
