# =============================================================================
# ZYLVEX TECHNOLOGIES — Environment Variables Reference
# Copy relevant sections to each service's .env file
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# =============================================================================
# FULL-STACK docker-compose.full-stack.yml — set these before running compose
# =============================================================================

# --- JWT (shared across auth service) ---
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-with-secrets-token-hex-32

# --- PostgreSQL passwords (used by both postgres services and app DATABASE_URLs) ---
# REQUIRED — use strong random values in production
AUTH_DB_PASSWORD=auth_pass_changeme
SPATIAL_DB_PASSWORD=spatial_pass_changeme
MM_DB_PASSWORD=mm_pass_changeme
SOCIAL_DB_PASSWORD=social_pass_changeme
NOTIF_DB_PASSWORD=notif_pass_changeme

# --- Redis cache (used by spatial-canvas and mind-mapper for token caching) ---
# Defaults to redis://cache:6379 inside compose; override for external Redis
REDIS_URL=redis://cache:6379

# --- SendGrid (notifications service) ---
# Optional — leave blank to disable email delivery
SENDGRID_API_KEY=
EMAIL_FROM=noreply@zylvex.io

# =============================================================================
# SHARED AUTH SERVICE (shared/auth/.env)
# =============================================================================
# DATABASE_URL=postgresql://auth_user:<AUTH_DB_PASSWORD>@localhost:5432/auth_db
# REQUIRED — must match JWT_SECRET used by downstream services
# JWT_SECRET=change-me-generate-with-secrets-token-hex-32
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30
# BCRYPT_ROUNDS=12
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# =============================================================================
# SPATIAL CANVAS BACKEND (spatial-canvas/backend/.env)
# =============================================================================
# DATABASE_URL=postgresql://spatial_user:<SPATIAL_DB_PASSWORD>@localhost:5433/spatial_db
# AUTH_SERVICE_URL=http://localhost:8001
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# =============================================================================
# MIND MAPPER BACKEND (mind-mapper/backend-services/.env)
# =============================================================================
# DATABASE_URL=postgresql://mm_user:<MM_DB_PASSWORD>@localhost:5434/mm_db
# AUTH_SERVICE_URL=http://localhost:8001
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# =============================================================================
# SPATIAL CANVAS MOBILE (spatial-canvas/mobile/.env)
# =============================================================================
# EXPO_PUBLIC_API_URL=http://localhost:8000
# EXPO_PUBLIC_AUTH_URL=http://localhost:8001

# =============================================================================
# MIND MAPPER MOBILE (mind-mapper/mobile-bci/.env)
# =============================================================================
# EXPO_PUBLIC_API_URL=http://localhost:8002
# EXPO_PUBLIC_AUTH_URL=http://localhost:8001
