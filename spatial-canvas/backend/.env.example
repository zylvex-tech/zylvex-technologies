# Database
# REQUIRED — use the same password as SPATIAL_DB_PASSWORD in docker-compose
DATABASE_URL=postgresql://spatial_user:spatial_pass_changeme@localhost:5432/spatial_db

# Auth service
# REQUIRED — URL of the shared auth service
AUTH_SERVICE_URL=http://localhost:8001

# Redis cache for token verification (optional — disables cache if unset)
REDIS_URL=redis://localhost:6379

# Application
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO

# API
API_V1_STR=/api/v1
