# Database
# REQUIRED — use the same password as MM_DB_PASSWORD in docker-compose
DATABASE_URL=postgresql://mm_user:mm_pass_changeme@localhost:5433/mm_db

# Auth Service
AUTH_SERVICE_URL=http://localhost:8001

# Redis cache for token verification (optional — disables cache if unset)
REDIS_URL=redis://localhost:6379

# Application
DEBUG=true
PORT=8002

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
